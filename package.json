{
  "name": "@docgen/document-engine",
  "version": "2.0.0",
  "description": "Self-improving agentic document generation engine with pluggable document types",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/core/providers.js",
      "types": "./dist/core/providers.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp src/core/chartTemplate.html dist/core/chartTemplate.html",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "start": "node dist/bin/server.js",
    "worker": "node dist/bin/worker.js",
    "workbench": "node dist/bin/workbench.js",
    "workbench:cli": "node dist/workbench/cli.js",
    "eval": "tsx evals/run.ts",
    "eval:bristol": "tsx evals/run.ts evals/fixtures/bristol-fy27"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@react-pdf/renderer": "^4.3.0",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "pdf-to-img": "^4.3.0",
    "pg": "^8.13.0",
    "puppeteer": "^24.40.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.15.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
